{
  "name": "tandem-browser",
  "version": "1.10.0",
  "description": "Local-first Electron browser with a 253-tool MCP server, MCP/HTTP control surfaces, and built-in security controls",
  "main": "dist/main.js",
  "author": "Tandem Browser contributors",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hydro13/tandem-browser.git"
  },
  "bugs": {
    "url": "https://github.com/hydro13/tandem-browser/issues"
  },
  "homepage": "https://github.com/hydro13/tandem-browser",
  "keywords": [
    "browser",
    "electron",
    "ai",
    "automation",
    "security",
    "local-first"
  ],
  "scripts": {
    "dev": "node scripts/start.js",
    "start": "node scripts/start.js",
    "compile": "tsc && npm run bundle:preload",
    "watch": "tsc -w",
    "build": "tsc && npm run bundle:preload && electron-builder",
    "bundle:preload": "esbuild dist/preload/index.js --bundle --platform=node --external:electron --outfile=dist/preload/index.js --allow-overwrite",
    "mcp": "node dist/mcp/server.js",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "verify": "npm run compile && npm run lint && npm test && npm run check-consistency",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:security": "vitest run src/security/tests/",
    "test:extensions": "vitest run src/extensions/tests/",
    "lint": "eslint src/",
    "check-consistency": "node scripts/check-consistency.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/adm-zip": "^0.5.7",
    "acorn": "^8.16.0",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.6.2",
    "cors": "^2.8.5",
    "electron-updater": "^6.8.3",
    "express": "^4.21.0",
    "ffmpeg-static": "^5.3.0",
    "turndown": "^7.2.2",
    "ws": "^8.19.0"
  },
  "//": "Liquid Glass Lite — uncomment when package is ready",
  "// dependencies-future": {
    "@mblock/liquid-glass": "file:../liquid-glass-lite/packages/core"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/supertest": "^7.2.0",
    "@types/turndown": "^5.0.6",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "electron": "^40.6.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.0.3",
    "jsdom": "^29.0.2",
    "supertest": "^7.2.2",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "yauzl": "3.2.1"
  },
  "productName": "Tandem Browser",
  "build": {
    "appId": "com.tandem.browser",
    "artifactName": "tandem-browser-${version}-${arch}.${ext}",
    "files": [
      "dist/**/*",
      "shell/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "tandem-browser-${version}-${arch}.${ext}",
      "signAndEditExecutable": false,
      "publish": [
        {
          "provider": "github",
          "owner": "hydro13",
          "repo": "tandem-browser"
        }
      ]
    },
    "nsis": {
      "artifactName": "tandem-browser-${version}-${arch}-setup.${ext}"
    },
    "portable": {
      "artifactName": "tandem-browser-${version}-${arch}-portable.${ext}"
    },
    "linux": {
      "category": "Utility"
    }
  }
}
